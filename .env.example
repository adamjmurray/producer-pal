# --- LLM provider keys (chat UI / evals) ---
# Supported:
GEMINI_KEY=...
OPENAI_KEY=...
MISTRAL_KEY=...
OPENROUTER_KEY=...

# Possibly to be used for eval LLM-as-judge (e.g. Haiku 4.5)
ANTHROPIC_KEY=...

# Experimental
VERTEX_KEY=...
GROQ_KEY=...

# Not compatible until a backend LLM proxy is built to avoid CORS restrictions:
FIREWORKSAI_KEY=...
HUGGINGFACE_KEY=...

# --- Build / runtime feature flags ---
# These are read at build time by config/rollup.config.mjs (inlined into bundles)
# and at runtime by the MCP server / portal. Set to "true" to enable.

# Exposes the ppal-raw-live-api debugging tool. Use for local development only.
ENABLE_RAW_LIVE_API=false

# Exposes the ppal-code-exec tool and code-transform parameters. Use for local development only.
ENABLE_CODE_EXEC=false

# Exposes warp_markers in read-clip output. Experimental.
ENABLE_WARP_MARKERS=false

# Adds permissive CORS headers to the MCP server's Express app for local UI development.
ENABLE_DEV_CORS=false

# Enables file-based logging in the portal (npm/producer-pal-portal.js).
ENABLE_LOGGING=false
